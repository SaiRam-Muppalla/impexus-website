# Copy this file to .env.local and fill in real values.
# Never commit .env or .env.local — they are in .gitignore.

# Canonical site URL used for og:image, canonical links, and JSON-LD.
VITE_SITE_URL=https://impexus.co.in

# Google Apps Script Web App URL for the contact form.
# Deploy the script in scripts/google-apps-script.gs, then paste the /exec URL here.
VITE_FORM_ENDPOINT=
